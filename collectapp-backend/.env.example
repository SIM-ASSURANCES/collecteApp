# Serveur
PORT=5000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collectapp_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=change_this_secret_key_in_production
JWT_EXPIRES_IN=8h

# Wave Business API
WAVE_API_KEY=your_wave_api_key
WAVE_WEBHOOK_SECRET=your_webhook_secret
WAVE_MERCHANT_QR_CODE=your_merchant_qr_data
